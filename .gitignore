# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# compound-agent managed
.compound-agent/

# site/ (Astro app at site/) — its build output and deps
site/dist/
site/node_modules/
site/.astro/
site/.claude/

# IV — diffs captured on a visual mismatch. The baselines themselves
# (under test-baselines/{light,dark}/*.png) are committed.
site/test-baselines/**/*.actual.png

# Go — binaries built locally; release artifacts go through goreleaser,
# never committed. *.test catches binaries `go test -c` leaves behind.
/c3p
/c3p.exe
**/*.test
dist/
