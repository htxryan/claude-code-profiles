{
  "name": "claude-code-config-profiles",
  "version": "0.4.0",
  "description": "Swappable .claude/ configurations for Claude Code projects",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "c3p": "dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver/index.d.ts",
      "import": "./dist/resolver/index.js"
    },
    "./merge": {
      "types": "./dist/merge/index.d.ts",
      "import": "./dist/merge/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/htxryan/claude-code-config-profiles.git"
  },
  "bugs": {
    "url": "https://github.com/htxryan/claude-code-config-profiles/issues"
  },
  "homepage": "https://github.com/htxryan/claude-code-config-profiles#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "keywords": [
    "claude",
    "claude-code",
    "profiles",
    "configuration",
    "cli"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "typecheck:src": "tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "compound-agent": "^2.7.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
