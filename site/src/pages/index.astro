---
// Marketing landing (R-U-1, R-U-4, R-U-5).
//
// Composition is intentionally shallow per Ousterhout: each marketing
// surface is one component, the page wires them together. No parallel
// design system — every visual value comes from `tokens.css`.

import '../styles/global.css';

import MetaHead from '../components/marketing/MetaHead.astro';
import ThemeInit from '../components/marketing/ThemeInit.astro';
import Hero from '../components/marketing/Hero.astro';
import FeatureCard from '../components/marketing/FeatureCard.astro';

const INSTALL_COMMAND = 'npm install -g claude-code-config-profiles';
const DOCS_HREF = '/docs/';
const REPO_URL = 'https://github.com/htxryan/claude-code-config-profiles';
const NPM_URL = 'https://www.npmjs.com/package/claude-code-config-profiles';
const LICENSE_URL = `${REPO_URL}/blob/main/LICENSE`;

const PERSONAS = [
  {
    persona: 'The solo dev',
    pitch: 'Experimental vs stable profiles without git stash hacks.',
  },
  {
    persona: 'The team lead',
    pitch: 'One source of truth for .claude/, shared across the team.',
  },
  {
    persona: 'The CI/CD engineer',
    pitch: 'Atomic, drift-proof swaps for deterministic agent runs.',
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <MetaHead
      title="C3P — Profile-based config swaps for Claude Code"
      description="Swap Claude Code configs across profiles without losing work. C3P refuses unsafe swaps when you have uncommitted edits to .claude/."
    />
    <ThemeInit />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__brand" aria-label="C3P home">C3P</a>
        <nav aria-label="Primary">
          <a href={DOCS_HREF}>Docs</a>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1" class="landing">
      <Hero installCommand={INSTALL_COMMAND} docsHref={DOCS_HREF} />

      <section class="personas" aria-labelledby="personas-title">
        <h2 id="personas-title" class="personas__title">Built for the way you ship</h2>
        <div class="personas__grid">
          {PERSONAS.map((p) => <FeatureCard persona={p.persona} pitch={p.pitch} />)}
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__links">
          <a href={REPO_URL} rel="noopener">GitHub</a>
          <span aria-hidden="true">&middot;</span>
          <a href={NPM_URL} rel="noopener">npm</a>
          <span aria-hidden="true">&middot;</span>
          <a href={LICENSE_URL} rel="noopener">License</a>
        </p>
        <p class="site-footer__voice">
          Programmed for etiquette and uncommitted-edit refusal.
        </p>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        background: var(--color-bg-surface);
      }

      .site-header__inner {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: var(--space-4) var(--space-5);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-5);
      }

      .site-header__brand {
        font-weight: 700;
        font-size: var(--type-scale-4);
        color: var(--color-text-primary);
        text-decoration: none;
        letter-spacing: var(--type-tracking-tight);
      }

      .landing {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: var(--space-6) var(--space-5) var(--space-8);
      }

      .personas {
        padding: var(--space-7) 0;
        border-top: 1px solid var(--color-border);
      }

      .personas__title {
        margin: 0 0 var(--space-6);
        font-size: var(--type-scale-5);
        line-height: var(--type-leading-tight);
        letter-spacing: var(--type-tracking-tight);
        text-align: center;
      }

      .personas__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-5);
      }

      @media (min-width: 48rem) {
        .personas__grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        background: var(--color-bg-surface);
      }

      .site-footer__inner {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: var(--space-6) var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        align-items: center;
        text-align: center;
      }

      .site-footer__links {
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        align-items: center;
        justify-content: center;
        color: var(--color-text-muted);
        font-size: var(--type-scale-2);
      }

      .site-footer__voice {
        margin: 0;
        color: var(--color-text-subtle);
        font-size: var(--type-scale-1);
        font-style: italic;
      }
    </style>
  </body>
</html>
