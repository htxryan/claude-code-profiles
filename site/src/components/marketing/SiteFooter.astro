---
// Shared site chrome — footer (R-U-1).
//
// Owns the footer frame and link-row styling. Pages provide the link
// list via the default slot, and an optional voice line via the
// `voice` named slot. Scoped styles keep `.site-footer*` rules from
// drifting between pages.
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__links"><slot /></p>
    {Astro.slots.has('voice') && (
      <p class="site-footer__voice"><slot name="voice" /></p>
    )}
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }

  .site-footer__inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    text-align: center;
  }

  .site-footer__links {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: var(--type-scale-2);
  }

  .site-footer__voice {
    margin: 0;
    color: var(--color-text-subtle);
    font-size: var(--type-scale-1);
    font-style: italic;
  }
</style>
