---
// Shared site chrome — header (R-U-1).
//
// Both `index.astro` and `404.astro` previously inlined identical
// `.site-header*` rules. Extracting here makes the CSS the single
// source of truth; Astro scopes the `<style>` block to this
// component so the class names cannot collide with anything else.

import { Image } from 'astro:assets';
import logoLight from '../../assets/c3p-logo-light.png';
import logoDark from '../../assets/c3p-logo-dark.png';

interface Props {
  docsHref?: string;
}

const { docsHref = '/docs/' } = Astro.props;
---
<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand" aria-label="C3P home">
      <Image
        src={logoDark}
        alt="C3P — Claude Code Config Profiles"
        class="site-header__logo site-header__logo--dark"
        height={36}
        loading="eager"
      />
      <Image
        src={logoLight}
        alt=""
        aria-hidden="true"
        class="site-header__logo site-header__logo--light"
        height={36}
        loading="eager"
      />
    </a>
    <nav aria-label="Primary">
      <a href={docsHref}>Docs</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }

  .site-header__inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  /* Both variants render; only the one matching the active theme is shown.
     Default is dark (matches site root); light wins under [data-theme="light"]
     — same convention as tokens.css so it stays in lockstep with the toggle. */
  .site-header__logo {
    display: block;
    width: auto;
    height: 36px;
  }

  .site-header__logo--light {
    display: none;
  }

  :root[data-theme='light'] .site-header__logo--dark {
    display: none;
  }

  :root[data-theme='light'] .site-header__logo--light {
    display: block;
  }
</style>
