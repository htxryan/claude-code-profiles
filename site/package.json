{
  "name": "@c3p/site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "getc3p.dev — marketing landing + Starlight docs (Astro SSG)",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "build": "playwright install chromium && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "og": "node scripts/build-og.mjs",
    "check:tokens": "astro build && node scripts/check-tokens.mjs",
    "iv": "node scripts/iv.mjs",
    "iv:fast": "node scripts/iv.mjs --skip-lighthouse",
    "iv:offline": "node scripts/iv.mjs --skip-lighthouse --skip-smoke",
    "iv:update-baselines": "node scripts/iv.mjs --skip-lighthouse --update-baselines"
  },
  "dependencies": {
    "@astrojs/starlight": "0.38.4",
    "astro": "6.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.11.3",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.2.0",
    "mermaid": "^11.14.0",
    "playwright": "^1.59.1",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.34.0",
    "typescript": "^5.7.2"
  }
}
